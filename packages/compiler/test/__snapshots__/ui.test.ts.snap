exports[`golden gates > key file content snapshots > app/src/main/java/io/appcraft/glucolog/MainActivity.kt 1`] = `
"package io.appcraft.glucolog

import android.os.Bundle
import androidx.activity.ComponentActivity
import androidx.activity.compose.setContent
import androidx.activity.enableEdgeToEdge
import androidx.compose.foundation.layout.padding
import androidx.compose.material3.Icon
import androidx.compose.material3.NavigationBar
import androidx.compose.material3.NavigationBarItem
import androidx.compose.material3.Scaffold
import androidx.compose.material3.Text
import androidx.compose.runtime.Composable
import androidx.compose.runtime.getValue
import androidx.compose.ui.Modifier
import androidx.navigation.compose.NavHost
import androidx.navigation.compose.composable
import androidx.navigation.compose.currentBackStackEntryAsState
import androidx.navigation.compose.rememberNavController
import io.appcraft.glucolog.ui.destinations
import io.appcraft.glucolog.ui.screens.*
import io.appcraft.glucolog.ui.theme.GlucoLogTheme

class MainActivity : ComponentActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        enableEdgeToEdge()
        AppGraph.init(applicationContext)
        setContent {
            GlucoLogTheme {
                AppRoot()
            }
        }
    }
}

@Composable
private fun AppRoot() {
    val navController = rememberNavController()
    Scaffold(
        bottomBar = {
            NavigationBar {
                val backStack by navController.currentBackStackEntryAsState()
                val currentRoute = backStack?.destination?.route
                destinations.forEach { dest ->
                    NavigationBarItem(
                        selected = currentRoute == dest.route,
                        onClick = {
                            navController.navigate(dest.route) {
                                launchSingleTop = true
                                restoreState = true
                                popUpTo(navController.graph.startDestinationId) { saveState = true }
                            }
                        },
                        icon = { Icon(dest.icon, contentDescription = dest.label) },
                        label = { Text(dest.label) },
                    )
                }
            }
        },
    ) { padding ->
        NavHost(
            navController = navController,
            startDestination = "logReading",
            modifier = Modifier.padding(padding),
        ) {
            composable("logReading") { LogReadingScreen() }
            composable("history") { HistoryScreen() }
            composable("findByDay") { FindByDayScreen() }
            composable("weeklyChart") { WeeklyChartScreen() }
        }
    }
}
"
`;

exports[`golden gates > key file content snapshots > app/src/main/java/io/appcraft/glucolog/domain/ModelFacade.kt 1`] = `
"package io.appcraft.glucolog.domain

import io.appcraft.glucolog.domain.gateway.GlucoseReadingGateway
import io.appcraft.glucolog.domain.model.*
import kotlinx.coroutines.flow.Flow
import kotlinx.coroutines.flow.map

/**
 * The use-case interactor facade. Depends exclusively on gateway interfaces
 * (dependency rule: source dependencies point inward). One method per flow.
 */
class ModelFacade(
    private val glucoseReadingGateway: GlucoseReadingGateway,
) {
    // flow: logReading (create GlucoseReading)
    suspend fun logReading(item: GlucoseReading) = glucoseReadingGateway.upsert(item)

    // flow: history (list GlucoseReading, by takenAt desc)
    fun history(): Flow<List<GlucoseReading>> = glucoseReadingGateway.observeAll().map { list -> list.sortedByDescending { it.takenAt } }

    // flow: findByDay (search GlucoseReading by takenAt; in-memory filter — v0.1 simplification for device-local data)
    fun findByDay(query: String): Flow<List<GlucoseReading>> =
        glucoseReadingGateway.observeAll().map { list -> list.filter { java.time.Instant.ofEpochMilli(it.takenAt).atZone(java.time.ZoneId.systemDefault()).toLocalDate().toString().startsWith(query.trim()) } }

    // chart data source
    fun observeGlucoseReading(): Flow<List<GlucoseReading>> = glucoseReadingGateway.observeAll()
}
"
`;

exports[`golden gates > key file content snapshots > app/src/main/java/io/appcraft/glucolog/ui/screens/LogReadingScreen.kt 1`] = `
"package io.appcraft.glucolog.ui.screens

import androidx.compose.foundation.layout.*
import androidx.compose.foundation.lazy.LazyColumn
import androidx.compose.foundation.lazy.items
import androidx.compose.foundation.rememberScrollState
import androidx.compose.foundation.verticalScroll
import androidx.compose.material.icons.Icons
import androidx.compose.material.icons.outlined.Search
import androidx.compose.material3.*
import androidx.compose.runtime.*
import androidx.compose.runtime.saveable.rememberSaveable
import androidx.compose.ui.Modifier
import androidx.compose.ui.text.input.KeyboardType
import androidx.compose.ui.unit.dp
import io.appcraft.glucolog.AppGraph
import io.appcraft.glucolog.domain.model.*
import io.appcraft.glucolog.ui.components.*
import kotlinx.coroutines.launch

@Composable
fun LogReadingScreen() {
    val facade = AppGraph.modelFacade
    val scope = rememberCoroutineScope()
    var mmol by rememberSaveable { mutableStateOf("") }
    val mmolValue = mmol.toDoubleOrNull()
    val takenAt = rememberSaveable { System.currentTimeMillis() }
    var context by rememberSaveable { mutableStateOf(ReadingContext.fasting) }
    var note by rememberSaveable { mutableStateOf("") }
    var mealPhoto by rememberSaveable { mutableStateOf<String?>(null) }
    var saved by remember { mutableStateOf(false) }
    val mmolError = when {
        mmol.isBlank() -> "Required"
        mmolValue == null -> "Enter a number"
        mmolValue != null && !(mmolValue > 0) -> "Must satisfy: mmol > 0"
        else -> null
    }
    val formValid = mmolError == null && mmolValue != null

    Column(
        modifier = Modifier
            .fillMaxSize()
            .verticalScroll(rememberScrollState())
            .padding(16.dp),
        verticalArrangement = Arrangement.spacedBy(12.dp),
    ) {
        Text("Log Reading", style = MaterialTheme.typography.headlineSmall)
        LabeledTextField(
            value = mmol,
            onValueChange = { mmol = it; saved = false },
            label = "Mmol",
            error = if (mmol.isBlank()) null else mmolError,
            keyboardType = KeyboardType.Decimal,
        )
        DateTimeChip(label = "Taken At", millis = takenAt)
        EnumDropdown(
            label = "Context",
            options = ReadingContext.entries,
            selected = context,
            onSelected = { context = it; saved = false },
            optionLabel = { it.name },
        )
        LabeledTextField(
            value = note,
            onValueChange = { note = it; saved = false },
            label = "Note",
        )
        ImagePickerField(label = "Meal Photo", uri = mealPhoto, onPicked = { mealPhoto = it; saved = false })
        Button(
            onClick = {
                scope.launch {
                    facade.logReading(
                        GlucoseReading(
                            id = java.util.UUID.randomUUID().toString(),
                            mmol = mmolValue!!,
                            takenAt = takenAt,
                            context = context,
                            note = note.trim().ifBlank { null },
                            mealPhoto = mealPhoto,
                        ),
                    )
                    saved = true
                }
            },
            enabled = formValid,
            modifier = Modifier.fillMaxWidth(),
        ) {
            Text("Save")
        }
        if (saved) {
            Text("Saved", color = MaterialTheme.colorScheme.primary)
        }
    }
}
"
`;

